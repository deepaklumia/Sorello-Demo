datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RestaurantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARED
  COMPLETED
  DECLINED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum UserRole {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  STAFF
}

model Restaurant {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  email            String            @unique
  phone            String
  address          String
  status           RestaurantStatus  @default(ACTIVE)
  subscriptionPlan String            @map("subscription_plan")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")
  slug             String            @unique
  password         String

  orders           Order[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  hours            RestaurantHours[]

  @@map("restaurants")
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  restaurantId  String        @db.Uuid @map("restaurant_id")
  customerName  String        @map("customer_name")
  totalAmount   Decimal       @db.Decimal(10, 2) @map("total_amount")
  orderStatus   OrderStatus   @default(PENDING) @map("order_status")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  createdAt     DateTime      @default(now()) @map("created_at")

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model MenuCategory {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @db.Uuid @map("restaurant_id")
  name         String
  description  String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id              String       @id @default(uuid()) @db.Uuid
  restaurantId    String       @db.Uuid @map("restaurant_id")
  categoryId      String       @db.Uuid @map("category_id")
  name            String
  description     String?
  imageUrl        String?      @map("image_url")
  price           Decimal      @db.Decimal(10, 2)
  preparationTime Int          @map("preparation_time")
  isAvailable     Boolean      @default(true) @map("is_available")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  restaurant      Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model RestaurantHours {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @db.Uuid @map("restaurant_id")
  dayOfWeek    Int        @map("day_of_week") // 0 = Sunday, 1 = Monday, etc.
  openingTime  String     @map("opening_time") // e.g. "08:00"
  closingTime  String     @map("closing_time") // e.g. "22:00"
  isClosed     Boolean    @default(false) @map("is_closed")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@map("restaurant_hours")
}
